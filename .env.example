# fail2ban コンテナの基本設定です。

# コンテナ内タイムゾーンです。
TZ=Asia/Tokyo

# reverse proxy のログディレクトリです。
# ここを見て ban 判定を行います。
PROXY_LOG_DIR=../infra-reverse-proxy/data/log

# Discord 通知を有効にする場合に設定します。
# 未設定のままなら通知スクリプトは fail2ban 状態確認のみで終了します。
DISCORD_WEBHOOK_URL=
DISCORD_NOTIFY_STATE_DIR=./runtime/discord-notify
DISCORD_NOTIFY_LOG_FILE=./runtime/docker-fail2ban-discord.log
# 未設定なら Docker Compose の fail2ban service を自動検出します。
DISCORD_NOTIFY_CONTAINER=
